<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_app"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="serif"
            android:text="@string/settings_title"
            android:textColor="@color/lss_ink"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:lineSpacingExtra="3dp"
            android:text="@string/settings_subtitle"
            android:textColor="@color/lss_muted"
            android:textSize="15sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/card_surface"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.06"
                android:text="@string/settings_section_receiver"
                android:textColor="@color/lss_muted"
                android:textSize="12sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/serverNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/input_surface"
                android:hint="@string/server_name_hint"
                android:inputType="text"
                android:textColor="@color/lss_ink"
                android:textColorHint="@color/lss_muted" />

            <EditText
                android:id="@+id/baseUrlInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_surface"
                android:hint="@string/base_url_hint"
                android:inputType="textUri"
                android:textColor="@color/lss_ink"
                android:textColorHint="@color/lss_muted" />

            <EditText
                android:id="@+id/authTokenInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_surface"
                android:hint="@string/auth_token_hint"
                android:inputType="textVisiblePassword"
                android:textColor="@color/lss_ink"
                android:textColorHint="@color/lss_muted" />

            <EditText
                android:id="@+id/fingerprintInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/input_surface"
                android:hint="@string/fingerprint_hint"
                android:inputType="textVisiblePassword"
                android:textColor="@color/lss_ink"
                android:textColorHint="@color/lss_muted" />

            <TextView
                android:id="@+id/settingsStatusText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/settings_hint"
                android:textColor="@color/lss_muted"
                android:textSize="14sp" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/button_primary"
                android:text="@string/save_config"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/backButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:background="@drawable/button_outline"
                android:text="@string/back_to_transfer"
                android:textAllCaps="false"
                android:textColor="@color/lss_teal"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
